# GitHub — admin panel publishes content via GitHub API (triggers Vercel rebuild)
GH_PAT=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# Admin — password gate for /admin (set to anything; share with James separately)
ADMIN_PASSWORD=

# Musician portal — signs session cookies (generate a long random string)
SESSION_SECRET=

# Artist invites — emails the self-signup link via Resend (optional).
# Without RESEND_API_KEY the admin panel falls back to a copy-able link.
RESEND_API_KEY=
# "From" address. Until stormymondaymia.com is verified in Resend, use the test
# sender below; after verification switch to e.g. "Stormy Monday <invites@stormymondaymia.com>"
INVITE_FROM=Stormy Monday <onboarding@resend.dev>
# Replies to invite emails go here (James' email)
INVITE_REPLY_TO=
# Base URL used to build invite links (optional; defaults to the request origin)
SITE_URL=
